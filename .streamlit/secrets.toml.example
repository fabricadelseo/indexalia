# Copia este fichero a  .streamlit/secrets.toml  (local) o pega su contenido en
# Streamlit Community Cloud -> Settings -> Secrets.
#
# Para el modo ONLINE multiusuario necesitas: passwords + google_oauth_token +
# sheet_id. La cuenta de servicio es solo una alternativa a OAuth.

# ----- 1) Login del equipo -----
# Una sola clave compartida por todos (lo más simple):
app_password = "clave-del-equipo"
# Alternativa: usuarios individuales (en vez de app_password):
# [passwords]
# ana   = "cambia-esta-clave"
# pedro = "cambia-esta-clave"

# ----- 2) Acceso a Google vía OAuth (recomendado) -----
# Pega aquí TODO el contenido de token.json (usa: python exportar_token.py).
google_oauth_token = '''
{"token": "...", "refresh_token": "...", "client_id": "...", "client_secret": "...", "scopes": ["..."]}
'''

# ----- 3) Cola compartida en Google Sheets -----
sheet_id = "ID_DE_TU_HOJA"

# ----- 4) IndexNow (opcional, Bing/Yandex) -----
# indexnow_key = "tu-key-de-indexnow"

# ----- (Alternativa a OAuth) Cuenta de servicio -----
# [gcp_service_account]
# type = "service_account"
# project_id = "tu-proyecto"
# private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# client_email = "indexador@tu-proyecto.iam.gserviceaccount.com"
# ... (resto de campos del JSON)
